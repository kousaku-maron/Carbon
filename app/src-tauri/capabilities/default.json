{
  "identifier": "default",
  "description": "Default capabilities for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "dialog:default",
    "fs:allow-read-dir",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-mkdir",
    "fs:allow-rename",
    "fs:allow-remove",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [
        "**",
        "**/.*",
        "**/.*/**"
      ]
    },
    "deep-link:default",
    "http:default",
    "os:default",
    "opener:default"
  ]
}
