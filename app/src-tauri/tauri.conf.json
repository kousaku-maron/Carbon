{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Carbon",
  "version": "0.1.11",
  "identifier": "dev.maron.carbon",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Carbon",
        "width": 1200,
        "height": 820,
        "resizable": true,
        "dragDropEnabled": false
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "carbon"
        ]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/kousaku-maron/Carbon/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBCQjEwOTgzRkJGRTc0MEEKUldRS2RQNzdnd214QzgvRlpyb0lOZVBwYWYwcEdkNDgreklad0syVWdUKzlQRTJKdVN6TEVsdy8K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
